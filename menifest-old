{
  "manifest_version": 3,
  "name": "Magic Fill Pro - Smart Auto Filler",
  "version": "2.0.0",
  "description": "AI-powered smart form filler with multi-model support and intelligent field detection",
  "author": "Md Khaleeque Akhtar",
  "permissions": [
    "storage",
    "clipboardRead",
    "clipboardWrite",
    "activeTab",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>",
    "https://api.openai.com/*",
    "https://generativelanguage.googleapis.com/*",
    "https://api.anthropic.com/*",
    "https://api.deepseek.com/*",
    "https://api.mistral.ai/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options/options.html",
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["utils.js", "field-detector.js", "ai-manager.js", "content.js"],
    
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [{
    "resources": ["dashboard/dashboard.html", "icons/*"],
    "matches": ["<all_urls>"]
  }],
  "commands": {
    "trigger-fill": {
      "suggested_key": {
        "default": "Ctrl+Shift+F",
        "mac": "Command+Shift+F"
      },
      "description": "Trigger auto-fill on current page"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}

